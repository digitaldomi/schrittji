<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_background"
        android:elevation="0dp"
        android:title="@string/settings"
        android:titleTextColor="@color/brand_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/textActionsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_actions"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/brand_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonGrantPermission"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/grant_health_permission" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenHealthConnect"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/open_health_connect" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSyncNow"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/publish_missing_recent_data" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenHealthBrowser"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/open_health_data_browser" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchBackgroundService"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/background_service_title"
                android:textColor="@color/brand_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="2dp"
                android:text="@string/background_service_interval"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/brand_text"
                android:alpha="0.75" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDailySteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/enable_daily_steps"
                android:textColor="@color/brand_text" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMinSteps"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/minimum_daily_steps"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMinSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMaxSteps"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/maximum_daily_steps"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMaxSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/running_workouts"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/brand_text" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchRunningEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/enable_running_workouts"
                android:textColor="@color/brand_text" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputRunningMinSessions"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/min_sessions_per_week"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editRunningMinSessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputRunningMaxSessions"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/max_sessions_per_week"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editRunningMaxSessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputRunningMinDuration"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/min_duration_minutes"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editRunningMinDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputRunningMaxDuration"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/max_duration_minutes"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editRunningMaxDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/cycling_workouts"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/brand_text" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchCyclingEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/enable_cycling_workouts"
                android:textColor="@color/brand_text" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputCyclingMinSessions"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/min_sessions_per_week"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCyclingMinSessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputCyclingMaxSessions"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/max_sessions_per_week"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCyclingMaxSessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputCyclingMinDuration"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/min_duration_minutes"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCyclingMinDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputCyclingMaxDuration"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/max_duration_minutes"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCyclingMaxDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/mindfulness_workouts"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/brand_text" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchMindfulnessEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/enable_mindfulness_workouts"
                android:textColor="@color/brand_text" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMindfulnessMinSessions"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/min_sessions_per_week"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMindfulnessMinSessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMindfulnessMaxSessions"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/max_sessions_per_week"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMindfulnessMaxSessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMindfulnessMinDuration"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/min_duration_minutes"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMindfulnessMinDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMindfulnessMaxDuration"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/max_duration_minutes"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMindfulnessMaxDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSaveSettings"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:text="@string/save_settings" />
</LinearLayout>

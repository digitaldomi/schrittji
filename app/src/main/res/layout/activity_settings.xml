<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_background"
        android:elevation="0dp"
        android:titleTextColor="@color/brand_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/settings_screen_headline"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/brand_text" />

            <TextView
                android:id="@+id/textActionsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_actions"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/brand_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonGrantPermission"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="48dp"
                android:text="@string/grant_health_permission" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenHealthConnect"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="48dp"
                android:text="@string/open_health_connect" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSyncNow"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="48dp"
                android:text="@string/publish_missing_recent_data" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenHealthBrowser"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="48dp"
                android:text="@string/open_health_data_browser" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchBackgroundService"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/background_service_title"
                android:textColor="@color/brand_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="2dp"
                android:text="@string/background_service_interval"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/brand_text"
                android:alpha="0.75" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDailySteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/enable_daily_steps"
                android:textColor="@color/brand_text" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMinSteps"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/minimum_daily_steps"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMinSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputMaxSteps"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/maximum_daily_steps"
                app:boxBackgroundColor="@android:color/white"
                app:boxStrokeColor="@color/brand_primary_dark"
                app:hintTextColor="@color/brand_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMaxSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_text"
                    android:textColorHint="@color/brand_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/activity_settings"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/brand_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/running_workouts"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textColor="@color/brand_text" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchRunningEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/enable_running_workouts"
                android:textColor="@color/brand_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/sessions_per_week_range"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/brand_text" />

            <TextView
                android:id="@+id/textRunningSessionsValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/brand_text"
                android:alpha="0.85" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderRunningSessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:stepSize="1"
                android:valueFrom="0"
                android:valueTo="7"
                app:labelBehavior="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/session_duration_range"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/brand_text" />

            <TextView
                android:id="@+id/textRunningDurationValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/brand_text"
                android:alpha="0.85" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderRunningDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="1"
                android:valueFrom="10"
                android:valueTo="240"
                app:labelBehavior="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/cycling_workouts"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                android:textColor="@color/brand_text" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchCyclingEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/enable_cycling_workouts"
                android:textColor="@color/brand_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/sessions_per_week_range"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/brand_text" />

            <TextView
                android:id="@+id/textCyclingSessionsValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/brand_text"
                android:alpha="0.85" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderCyclingSessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="1"
                android:valueFrom="0"
                android:valueTo="7"
                app:labelBehavior="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/session_duration_range"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/brand_text" />

            <TextView
                android:id="@+id/textCyclingDurationValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/brand_text"
                android:alpha="0.85" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderCyclingDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="1"
                android:valueFrom="10"
                android:valueTo="240"
                app:labelBehavior="gone" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSaveSettings"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:text="@string/save_settings" />
</LinearLayout>

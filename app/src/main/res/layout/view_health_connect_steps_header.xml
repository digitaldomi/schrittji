<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonRefresh"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/refresh_health_connect_steps" />

    <TextView
        android:id="@+id/textSummaryHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/health_connect_steps_summary_header"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <TextView
        android:id="@+id/textSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_background"
        android:padding="16dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

    <TextView
        android:id="@+id/textDailyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/health_connect_steps_daily_chart_header"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <dev.digitaldomi.schrittji.chart.SimpleBarChartView
        android:id="@+id/chartDaily"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_background"
        android:padding="12dp" />

    <TextView
        android:id="@+id/textDailySummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_background"
        android:padding="16dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

    <TextView
        android:id="@+id/textWeeklyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/health_connect_steps_weekly_chart_header"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

    <dev.digitaldomi.schrittji.chart.SimpleBarChartView
        android:id="@+id/chartWeekly"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_background"
        android:padding="12dp" />

    <TextView
        android:id="@+id/textWeeklySummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_background"
        android:padding="16dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

    <TextView
        android:id="@+id/textRecordsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:text="@string/health_connect_steps_records_header"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
</LinearLayout>
